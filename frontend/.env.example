# Base URL of the LedgerAI backend API (its /api/v1 root, ADR-011). Environment-driven and public by
# nature — Vite exposes VITE_* variables to the client, so secrets must never be placed here.
# Leave unset to fall back to the same-origin /api/v1 path (useful with a local dev proxy).
VITE_API_BASE_URL=
